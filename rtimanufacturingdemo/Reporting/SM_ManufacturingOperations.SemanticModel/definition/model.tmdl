model Model
	culture: en-US
	defaultPowerBIDataSourceVersion: powerBI_V3
	sourceQueryCulture: en-US
	dataAccessOptions
		legacyRedirects
		returnErrorValuesAsNull

annotation PBI_QueryOrder = ["DirectLake - ManufacturingData"]

annotation __PBI_TimeIntelligenceEnabled = 0

annotation PBI_ProTooling = ["TMDLView_Desktop","RemoteModeling","WebModelingEdit","DaxCopilot_Change_Accepted_In_Desktop","DaxQueryView_Desktop","DirectLakeOnOneLakeInWeb"]

ref table sites
ref table dim_date
ref table sensor_data
ref table oee
ref table machines

ref role SiteMunich

