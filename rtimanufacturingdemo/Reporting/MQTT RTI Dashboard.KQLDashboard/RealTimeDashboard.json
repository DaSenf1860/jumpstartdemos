      },
      "text": "// Query flattened data (use this to verify the policy is working)\nproduction_quality\n| where timestamp > ago(30m) and production_line == \"LINE-2\"\n| extend TimeBin = bin(timestamp, 1m)\n| extend pass_rate_percentage = pass_rate_percentage/100\n| summarize avg(first_pass_yield), avg(dimensional_check), avg(surface_quality), avg(electrical_test), avg(performance_test), avg(pass_rate_percentage) by TimeBin, production_line\n\n",
      "id": "bdee7e80-ba3f-401f-a5a4-2bbc0eb70e7c",
