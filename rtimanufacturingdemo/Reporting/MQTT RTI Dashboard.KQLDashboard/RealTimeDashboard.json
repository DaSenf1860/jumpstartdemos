      },
      "text": "// Query flattened data (use this to verify the policy is working)\nproduction_quality\n| where timestamp > ago(30min)\n| order by timestamp desc\n| limit 100\n",
      "id": "c0ec2918-d227-4bf2-bbec-8a97268fa6b2",
      "usedVariables": []
    },
    {
      "dataSource": {
        "kind": "inline",
        "dataSourceId": "a6591953-5965-42d1-9053-ae56df8a37ec"
      },
      "text": "// Query flattened data (use this to verify the policy is working)\nproduction_quality\n| where timestamp > ago(30m) and production_line == \"LINE-1\"\n| extend TimeBin = bin(timestamp, 1m)\n| extend pass_rate_percentage = pass_rate_percentage/100\n| summarize avg(first_pass_yield), avg(dimensional_check), avg(surface_quality), avg(electrical_test), avg(performance_test), avg(pass_rate_percentage) by TimeBin, production_line\n\n",
      "id": "3e41ed5e-9c93-4d39-95e4-4a600b86b6cc",
      "usedVariables": []
    },
    {
      "dataSource": {
        "kind": "inline",
